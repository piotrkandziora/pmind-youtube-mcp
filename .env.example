# PMIND MCP Youtube Configuration

# Configuration directory (default: '~/.pmind-youtube-mcp')
# client_secrets.json and token.json will be stored here
CONFIG_DIR=~/.pmind-youtube-mcp

# Default language for raw transcript extraction (optional, default: 'en')
# This is used by transcripts_get_transcript to fetch existing YouTube captions/subtitles
# Not used for AI-generated transcripts (see GEMINI_MODEL for that)
# Use ISO 639-1 two-letter codes (en, es, fr, de, ja, etc.)
YOUTUBE_RAW_TRANSCRIPT_LANG=en

# Gemini AI Configuration (optional - for Gemini tools)
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Default Gemini model to use
# Examples: gemini-2.5-flash, gemini-2.5-pro, gemini-exp-1206
GEMINI_MODEL=gemini-2.5-flash

# Directory for storing upload state files (optional, default: '/tmp/pmind-youtube-mcp-uploads')
# Upload sessions track progress and status in JSON files in this directory
# Examples:
#   YOUTUBE_UPLOAD_STATE_DIR=/var/lib/pmind-youtube-mcp/uploads
#   YOUTUBE_UPLOAD_STATE_DIR=~/.pmind-youtube-mcp/uploads
#   YOUTUBE_UPLOAD_STATE_DIR=./uploads
YOUTUBE_UPLOAD_STATE_DIR=/tmp/pmind-youtube-mcp-uploads